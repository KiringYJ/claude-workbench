#!/bin/bash
# Auto-bump plugin patch version when plugin files are staged.
# Skips if only plugin.json itself changed.
# Also syncs bumped versions into marketplace.json.

MARKETPLACE=".claude-plugin/marketplace.json"
marketplace_changed=0

for plugin_json in plugins/*/.claude-plugin/plugin.json; do
    [ -f "$plugin_json" ] || continue
    plugin_dir=$(dirname "$(dirname "$plugin_json")")

    # Check if any files in this plugin dir are staged (excluding plugin.json)
    staged=$(git diff --cached --name-only -- "$plugin_dir" | grep -v '.claude-plugin/plugin.json')
    [ -z "$staged" ] && continue

    # Bump patch version via python
    python3 -c "
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
d = json.loads(p.read_text())
parts = d['version'].split('.')
parts[-1] = str(int(parts[-1]) + 1)
d['version'] = '.'.join(parts)
p.write_text(json.dumps(d, indent=2) + '\n')
print(f'  plugin {d[\"name\"]}: {\".\".join(parts[:-1] + [str(int(parts[-1])-1)])} -> {d[\"version\"]}')
" "$plugin_json"

    git add "$plugin_json"

    # Sync version into marketplace.json
    if [ -f "$MARKETPLACE" ]; then
        plugin_name=$(python3 -c "
import json, sys
print(json.loads(open(sys.argv[1]).read())['name'])
" "$plugin_json")
        new_version=$(python3 -c "
import json, sys
print(json.loads(open(sys.argv[1]).read())['version'])
" "$plugin_json")
        python3 -c "
import json, pathlib, sys
name, version = sys.argv[1], sys.argv[2]
p = pathlib.Path(sys.argv[3])
d = json.loads(p.read_text())
for plugin in d.get('plugins', []):
    if plugin['name'] == name:
        plugin['version'] = version
        break
p.write_text(json.dumps(d, indent=2) + '\n')
" "$plugin_name" "$new_version" "$MARKETPLACE"
        marketplace_changed=1
    fi
done

if [ "$marketplace_changed" -eq 1 ]; then
    git add "$MARKETPLACE"
fi
