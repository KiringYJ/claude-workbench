      "rules": ["core", "rust", "python"],
      "plugins": [
        "core@workbench",
        "rust@workbench",
        "python@workbench",
        "oh-my-claudecode@omc",
        "ralph-loop@claude-plugins-official",
        "hookify@claude-plugins-official",
        "claude-md-management@claude-plugins-official",
        "skill-creator@claude-plugins-official",
